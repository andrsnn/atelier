{
  "name": "atelier",
  "version": "3.0.0",
  "license": "MIT",
  "private": true,
  "bin": {
    "atelier": "./cli/atelier.mjs"
  },
  "scripts": {
    "dev": "next dev --port 7777",
    "build": "next build",
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next start --port 7777",
    "lint": "next lint",
    "tui": "node cli/atelier.mjs",
    "tailnet": "node scripts/serve-tailnet.mjs",
    "readiness": "node scripts/publish-readiness.mjs",
    "readiness:fix": "node scripts/publish-readiness.mjs --fix",
    "publish:public": "node scripts/publish-public.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cross-env": "^10.1.0",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "ollama": "^0.6.3",
    "puppeteer-core": "^25.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
